'''swapping string from camel case to snake case'''

s="if_you_are_good_at_something_never_do_it_for_free"
s1=" "
s1+=chr(ord(s[0])-32)
for i in range(1,len(s)):
    if s[i]=="_":
        s1+=" "
    else:
        if s[i-1]=='_':
            s1+=chr(ord(s[i])-32)
        else:
            s1+=s[i]
print(s1)
