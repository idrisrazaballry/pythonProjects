'''' Checking list whether it is child list or not'''
def funct(l1,l2):
    for i in range(len(l1)):
        if l1[i:i+len(l2)]==l2:
            return True
    return False

l1=[1,2,3,4,5,6,7,8]
l2=[3,4,5]
if funct(l1,l2):
    print('l2 is child list of l1')
else:
    print('l2 is not child of l1')
